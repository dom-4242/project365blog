# ============================================
# Project 365 Blog — Umgebungsvariablen
# ============================================
# Kopiere diese Datei nach .env.local und fülle die Werte aus:
#   cp .env.example .env.local
#
# WICHTIG: .env.local gehört NICHT ins Git!
# ============================================

# --- Datenbank ---
DATABASE_URL="postgresql://project365:changeme@localhost:5432/project365blog"

# --- NextAuth.js ---
# Generiere ein Secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --- Google OAuth (Admin-Login) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ADMIN_EMAIL=""          # Deine Google-Email — nur dieser Account hat Zugang

# --- Fitbit API (OAuth 2.0) ---
# Registriere eine App unter: https://dev.fitbit.com/apps/new
# Application Type: "Personal"
# Callback URL: http://localhost:3000/api/fitbit/callback
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""
FITBIT_ACCESS_TOKEN=""
FITBIT_REFRESH_TOKEN=""

# --- Cron-Job Auth ---
# Schützt /api/cron/* Routen. Header: Authorization: Bearer <secret>
# Generiere einen sicheren Key: openssl rand -hex 32
CRON_SECRET=""

# --- Apple Health Import ---
# API-Key für den Health Auto Export Webhook
# Generiere einen sicheren Key: openssl rand -hex 32
HEALTH_IMPORT_API_KEY=""

# --- Claude API (AI-Übersetzung Journal-Einträge DE → EN) ---
# Anthropic Console: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# --- Analytics (Privacy-first, selbst gehostet) ---
# Schützt /api/internal/* Routen
INTERNAL_SECRET=""
# Salt für IP/UA-Hashing — nie ändern, sonst werden alle Sessions ungültig
ANALYTICS_SALT=""

# --- Docker (für docker-compose.yml) ---
DB_PASSWORD="changeme"
