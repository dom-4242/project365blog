// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

// =============================================
// JOURNAL-EINTRÄGE — Content + eingebettete Habits
// Quelle: Web-Editor (Admin, eingeloggt)
// =============================================

model JournalEntry {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  excerpt   String?
  bannerUrl String?
  tags      String[]
  date      DateTime @db.Date
  published Boolean  @default(true)

  // Die drei Säulen — direkt eingebettet
  movement  MovementLevel
  nutrition NutritionLevel
  smoking   SmokingStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions   Reaction[]
  translation Translation?

  @@index([date])
  @@index([published])
}

// =============================================
// ÜBERSETZUNGEN — AI-generierte EN-Übersetzungen
// Quelle: Claude API (DE → EN)
// =============================================

model Translation {
  id        String       @id @default(cuid())
  entryId   String       @unique
  locale    String       @default("en")
  title     String
  content   String       @db.Text
  excerpt   String?
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum MovementLevel {
  MINIMAL
  STEPS_ONLY
  STEPS_TRAINED
}

enum NutritionLevel {
  NONE
  ONE
  TWO
  THREE
}

enum SmokingStatus {
  SMOKED
  REPLACEMENT
  NONE
}

// =============================================
// METRIKEN — Objektive Messwerte
// Quelle: Automatisch (Fitbit/Apple Health) + Manuell
// =============================================

model DailyMetrics {
  id             String       @id @default(cuid())
  date           DateTime     @unique @db.Date
  weight         Float?
  bodyFat        Float?
  bmi            Float?
  steps          Int?
  activeMinutes  Int?
  caloriesBurned Int?
  distance       Float?
  restingHR      Int?
  sleepDuration  Int?
  source         MetricSource @default(MANUAL)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([date])
}

enum MetricSource {
  MANUAL
  FITBIT
  APPLE_HEALTH
  MERGED
}

// =============================================
// BENUTZER-PROFIL — Statische persönliche Werte
// Singleton-Zeile (id = "singleton")
// =============================================

model UserProfile {
  id           String   @id @default("singleton")
  heightCm     Float?   // Körpergrösse in cm
  targetWeight Float?   // Zielgewicht in kg
  targetSteps  Int?     // Tagesziel Schritte
  updatedAt    DateTime @updatedAt
}

// =============================================
// EMOJI-REACTIONS — Leser-Interaktion
// =============================================

model Reaction {
  id           String       @id @default(cuid())
  emoji        ReactionType
  ipHash       String
  journalEntry JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId      String
  createdAt    DateTime     @default(now())

  @@unique([entryId, emoji, ipHash])
  @@index([entryId])
}

enum ReactionType {
  HEART
  CLAP
  FIRE
  MUSCLE
  STAR
}

// =============================================
// MONATS-ZUSAMMENFASSUNGEN — AI-generierte Rückblicke
// Quelle: Claude API, einmal pro Monat generiert
// =============================================

model MonthSummary {
  id          String   @id @default(cuid())
  year        Int
  month       Int      // 1–12
  contentDe   String   @db.Text
  contentEn   String?  @db.Text
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

// =============================================
// SEITENAUFRUFE — Privacy-first Analytics
// Kein Cookie, keine IP-Speicherung
// sessionHash = SHA-256(IP+UA+Date+Salt), tagesbezogen
// =============================================

model PageView {
  id          String   @id @default(cuid())
  path        String                          // Normalisierter Pfad ohne Locale (/journal/slug)
  referrer    String?                         // Nur Hostname des Referrers
  sessionHash String                          // Tagesbezogener Hash — nie auf Person zurückführbar
  timestamp   DateTime @default(now())

  @@index([timestamp])
  @@index([path])
}
