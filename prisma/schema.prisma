// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

// =============================================
// JOURNAL-EINTRÄGE — Content + eingebettete Habits
// Quelle: Web-Editor (Admin, eingeloggt)
// =============================================

model JournalEntry {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  excerpt   String?
  bannerUrl String?
  tags      String[]
  date      DateTime @db.Date
  published Boolean  @default(true)

  // Die drei Säulen — direkt eingebettet
  movement  MovementLevel
  nutrition NutritionLevel
  smoking   SmokingStatus

  // Süssigkeiten: null = nicht erfasst, false = keine, true = konsumiert
  sweetsConsumed Boolean?

  // Privates Notizfeld — niemals in öffentlichen Queries zurückgeben
  privateNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions    Reaction[]
  translations Translation[]

  @@index([date])
  @@index([published])
}

// =============================================
// ÜBERSETZUNGEN — AI-generierte EN-Übersetzungen
// Quelle: Claude API (DE → EN)
// =============================================

model Translation {
  id        String       @id @default(cuid())
  entryId   String
  locale    String       @default("en")
  title     String
  content   String       @db.Text
  excerpt   String?
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([entryId, locale])
}

enum MovementLevel {
  MINIMAL
  STEPS_ONLY
  TRAINED_ONLY
  STEPS_TRAINED
}

enum NutritionLevel {
  NONE
  ONE_MEAL
  TWO_MEALS
  THREE_MEALS
}

enum SmokingStatus {
  SMOKED
  NICOTINE_REPLACEMENT
  SMOKE_FREE
}

// =============================================
// METRIKEN — Objektive Messwerte
// Quelle: Automatisch (Fitbit/Apple Health) + Manuell
// =============================================

model DailyMetrics {
  id             String       @id @default(cuid())
  date           DateTime     @unique @db.Date
  weight         Float?
  bodyFat        Float?
  bmi            Float?
  steps          Int?
  activeMinutes  Int?
  caloriesBurned Int?
  distance       Float?
  restingHR      Int?
  sleepDuration  Int?
  source         MetricSource @default(MANUAL)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([date])
}

enum MetricSource {
  MANUAL
  FITBIT
  APPLE_HEALTH
  MERGED
}

// =============================================
// BENUTZER-PROFIL — Statische persönliche Werte
// Singleton-Zeile (id = "singleton")
// =============================================

model UserProfile {
  id               String   @id @default("singleton")
  heightCm         Float?   // Körpergrösse in cm
  targetWeight     Float?   // Zielgewicht in kg
  targetSteps      Int?     // Tagesziel Schritte
  projectStartDate String?  // Projekt-Startdatum YYYY-MM-DD (Default: 2026-03-26)
  updatedAt        DateTime @updatedAt
}

// =============================================
// EMOJI-REACTIONS — Leser-Interaktion
// =============================================

model Reaction {
  id           String       @id @default(cuid())
  emoji        ReactionType
  ipHash       String
  journalEntry JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId      String
  createdAt    DateTime     @default(now())

  @@unique([entryId, emoji, ipHash])
  @@index([entryId])
}

enum ReactionType {
  HEART
  CLAP
  FIRE
  MUSCLE
  STAR
}

// =============================================
// MONATS-ZUSAMMENFASSUNGEN — AI-generierte Rückblicke
// Quelle: Claude API, einmal pro Monat generiert
// =============================================

model MonthSummary {
  id          String   @id @default(cuid())
  year        Int
  month       Int      // 1–12
  contentDe   String   @db.Text
  contentEn   String?  @db.Text
  contentPt   String?  @db.Text
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

// =============================================
// PRIVATE FOTO-GALERIE — Körper-Zeitraffer (nur Admin)
// Dateien liegen unter /app/private/body-photos/ (ausserhalb public/)
// =============================================

model BodyPhoto {
  id        String        @id @default(cuid())
  filename  String        // gespeicherter Dateiname auf Disk
  date      DateTime      @db.Date
  category  PhotoCategory @default(FRONT)
  notes     String?
  createdAt DateTime      @default(now())

  @@index([date])
  @@index([category])
}

enum PhotoCategory {
  FRONT
  SIDE
  BACK
}

// =============================================
// MAHLZEITEN-LOG — tägliche Erfassung mit Bewertung
// =============================================

model MealLog {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  breakfast      Float?   // null = nicht eingenommen, 1.0–10.0
  snackMorning   Float?   // Zwischenmahlzeit Morgen
  lunch          Float?   // Mittagessen
  snackAfternoon Float?   // Zwischenmahlzeit Nachmittag
  dinner         Float?   // Abendessen
  snack          Float?   // Tages-Snack optional (Nüsse etc.) — Bonus
  score          Float?   // berechneter Tages-Score 0.0–5.0
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

// =============================================
// MAHLZEITEN-PLANUNG — Planung für den nächsten Tag
// =============================================

model MealPlan {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  breakfast      String?
  snackMorning   String?
  lunch          String?
  snackAfternoon String?
  dinner         String?
  snack          String?  // optionaler Bonus-Snack
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

// =============================================
// LESEN — Bücher und tägliche Seiten
// =============================================

model Book {
  id          String      @id @default(cuid())
  title       String
  author      String?
  totalPages  Int?
  startDate   DateTime?   @db.Date
  endDate     DateTime?   @db.Date
  completed   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  readingLogs ReadingLog[]

  @@index([completed])
}

model ReadingLog {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  pagesRead  Int
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([date, bookId])
  @@index([date])
  @@index([bookId])
}

// =============================================
// SEITENAUFRUFE — Privacy-first Analytics
// Kein Cookie, keine IP-Speicherung
// sessionHash = SHA-256(IP+UA+Date+Salt), tagesbezogen
// =============================================

// =============================================
// KÖRPERMASSE — Umfangmessungen mit Massband
// =============================================

model BodyMeasurement {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  chest         Float?   // Brustumfang cm
  waist         Float?   // Taillenumfang cm
  hip           Float?   // Hüftumfang cm
  upperArmLeft  Float?   // Oberarm links cm
  upperArmRight Float?   // Oberarm rechts cm
  thighLeft     Float?   // Oberschenkel links cm
  thighRight    Float?   // Oberschenkel rechts cm
  calfLeft      Float?   // Wade links cm
  calfRight     Float?   // Wade rechts cm
  neck          Float?   // Halsumfang cm (optional)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}

// =============================================
// GETRÄNKE-LOG — Schnellerfassung Wasser & Cola Zero
// =============================================

model DrinkLog {
  id        String    @id @default(cuid())
  type      DrinkType
  volume    Int       // ml
  timestamp DateTime  @default(now())

  @@index([timestamp])
}

enum DrinkType {
  WATER
  COLA_ZERO
}

// =============================================
// SÜSSIGKEITEN-LOG — tägliche Erfassung (unabhängig vom Journal-Eintrag)
// consumed = false → keine Süssigkeiten, true → konsumiert
// =============================================

model SweetsLog {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  consumed  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// =============================================
// APP SETTINGS — generischer Key-Value Store
// Wird u.a. für Fitbit OAuth Tokens genutzt
// =============================================

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// =============================================
// APPLE HEALTH INVENTAR — empfangene Metriken
// Wird bei jedem /api/health-import befüllt.
// Pro Metrik-Name eine Zeile (kein Rohdaten-Storage).
// =============================================

model HealthMetricInventory {
  metricName     String   @id                // z.B. "Stand Time", "Step Count"
  unit           String   @default("")       // z.B. "count", "hr", "kcal"
  sampleCount    Int      @default(0)        // Anzahl Datenpunkte im letzten Import
  lastValue      Float?                      // letzter qty/avg/asleep Wert
  lastValueDate  String?                     // YYYY-MM-DD des letzten Datenpunkts
  lastReceivedAt DateTime @default(now())    // Zeitpunkt des letzten Imports
  createdAt      DateTime @default(now())
}

model PageView {
  id          String   @id @default(cuid())
  path        String                          // Normalisierter Pfad ohne Locale (/journal/slug)
  referrer    String?                         // Nur Hostname des Referrers
  sessionHash String                          // Tagesbezogener Hash — nie auf Person zurückführbar
  timestamp   DateTime @default(now())

  @@index([timestamp])
  @@index([path])
}

// =============================================
// FITBIT SYNC LOG — Protokoll jeder Sync-Ausführung
// Wird von Cron und manuellem Sync befüllt.
// =============================================

model FitbitSyncLog {
  id              String   @id @default(cuid())
  syncedAt        DateTime @default(now())
  triggeredBy     String   @default("CRON")   // CRON | MANUAL
  syncDate        String                       // YYYY-MM-DD — der synchronisierte Tag
  status          String                       // SUCCESS | ERROR
  weight          Float?
  bodyFat         Float?
  bmi             Float?
  activeMinutes   Int?
  caloriesBurned  Int?
  distance        Float?
  restingHR       Int?
  tokensRefreshed Boolean  @default(false)
  errorMessage    String?

  @@index([syncedAt(sort: Desc)])
}
