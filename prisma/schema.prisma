// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =============================================
// JOURNAL-EINTRÄGE — Content + eingebettete Habits
// Quelle: Web-Editor (Admin, eingeloggt)
// =============================================

model JournalEntry {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  excerpt   String?
  bannerUrl String?
  tags      String[]
  date      DateTime @db.Date
  published Boolean  @default(true)

  // Die drei Säulen — direkt eingebettet
  movement  MovementLevel
  nutrition NutritionLevel
  smoking   SmokingStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions Reaction[]

  @@index([date])
  @@index([published])
}

enum MovementLevel {
  MINIMAL
  STEPS_ONLY
  STEPS_TRAINED
}

enum NutritionLevel {
  NONE
  ONE
  TWO
  THREE
}

enum SmokingStatus {
  SMOKED
  REPLACEMENT
  NONE
}

// =============================================
// METRIKEN — Objektive Messwerte
// Quelle: Automatisch (Fitbit/Apple Health) + Manuell
// =============================================

model DailyMetrics {
  id             String       @id @default(cuid())
  date           DateTime     @unique @db.Date
  weight         Float?
  bodyFat        Float?
  bmi            Float?
  steps          Int?
  activeMinutes  Int?
  caloriesBurned Int?
  distance       Float?
  restingHR      Int?
  sleepDuration  Int?
  source         MetricSource @default(MANUAL)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([date])
}

enum MetricSource {
  MANUAL
  FITBIT
  APPLE_HEALTH
  MERGED
}

// =============================================
// EMOJI-REACTIONS — Leser-Interaktion
// =============================================

model Reaction {
  id           String       @id @default(cuid())
  emoji        ReactionType
  ipHash       String
  journalEntry JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId      String
  createdAt    DateTime     @default(now())

  @@unique([entryId, emoji, ipHash])
  @@index([entryId])
}

enum ReactionType {
  HEART
  CLAP
  FIRE
  MUSCLE
  STAR
}
